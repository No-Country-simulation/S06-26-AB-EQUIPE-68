# =========================================================================
# Template de Configurações do Aplicativo BiT (Backend)
# Copie este arquivo para .env e preencha as variáveis de acordo com seu ambiente.
# =========================================================================

# Porta em que o servidor Spring Boot irá rodar
SERVER_PORT=8080

# -------------------------------------------------------------------------
# Banco de Dados (MySQL)
# -------------------------------------------------------------------------
DB_URL=jdbc:mysql://localhost:3306/db_bitapp?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=123456

# -------------------------------------------------------------------------
# JPA / Hibernate
# -------------------------------------------------------------------------
# Opções comuns: update, create, create-drop, validate, none
JPA_DDL_AUTO=update
# Exibir os SQLs executados no console (true/false)
JPA_SHOW_SQL=false

# -------------------------------------------------------------------------
# API do Google Gemini AI
# -------------------------------------------------------------------------
# COMO OBTER SUA API KEY GRATUITA:
# 1. Acesse: https://aistudio.google.com/app/apikey
# 2. Clique em "Create API key"
# 3. A chave começa com "AIzaSy..." — copie e cole abaixo
# ATENÇÃO: Chaves OAuth (começam com "AQ.") NÃO funcionam aqui!
GEMINI_API_KEY=AQ.Ab8RN6L68IGTgNWwcfSinxC11NGNtZZC2Paxb437bRFneJpT8
# Modelo gratuito recomendado: gemini-2.0-flash (1500 req/dia, sem custo)
# Alternativas gratuitas: gemini-2.0-flash-lite, gemini-1.5-flash-8b
GEMINI_MODEL=gemini-2.0-flash
GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_OUTPUT_TOKENS=2048

# -------------------------------------------------------------------------
# Dataset Vísent (Infraestrutura de Rede)
# -------------------------------------------------------------------------
# Habilita a ingestão automática dos CSVs na inicialização do servidor
# true  = carrega antenas_flp.csv e tensor_concentracao.csv ao subir
# false = não executa a ingestão (padrão recomendado para dev/CI)
VISENT_ENABLED=false
